{
  "name": "feyagate-desktop",
  "version": "1.2.18",
  "description": "FeyaGate Desktop — cross-platform Electron client for the FeyaGate MCP server",
  "main": "dist-electron/main.js",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/toddpan/feyagate-desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/toddpan/feyagate-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/toddpan/feyagate-desktop/issues"
  },
  "feyagate": {
    "serverVersion": "1.2.18",
    "serverRelease": "https://github.com/toddpan/miloco-mcp-server-releases/releases/download"
  },
  "scripts": {
    "postinstall": "node scripts/download-server.js",
    "server:fetch": "node scripts/download-server.js",
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "build:web": "tsc && vite build --config vite.config.web.ts",
    "dev:web": "vite --config vite.config.web.ts",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "antd": "^5.22.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
